{
  "builds": [
    { "src": "php/*.php", "use": "vercel-php@0.9.0" },
    { "src": "php/config/*.php", "use": "vercel-php@0.9.0" },
    { "src": "php/middleware/*.php", "use": "vercel-php@0.9.0" }
  ],
  "routes": [
    { "src": "/php/(.*)", "dest": "/php/$1" },
    { "src": "/(.*)",     "dest": "/$1"     }
  ]
}
